# Supabase (not required to run locally — the app uses an in-memory store until
# you wire these up in lib/store.ts). Copy to .env.local and fill in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — used by API routes for inserts. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Feeder ───────────────────────────────────────────────────────────────────
# URL of the board to push into (defaults to http://localhost:3000)
BOARD_URL=http://localhost:3000

# PagerMon: your remote PagerMon instance
PAGERMON_URL=https://your-pagermon-server
PAGERMON_KEY=your-pagermon-api-key

# Telegram: get API credentials from https://my.telegram.org/apps
# Then run:  npm run feeder:auth-telegram  to generate TG_SESSION
TG_API_ID=
TG_API_HASH=
TG_SESSION=
# The group to read from — use the title, @username, or numeric chat ID
TG_GROUP=

# ── Slack bot ────────────────────────────────────────────────────────────────
# Bot User OAuth token (xoxb-…). The bot must be invited to every area channel.
# Needs scope: chat:write. Leave blank to disable Slack posting entirely.
SLACK_BOT_TOKEN=
# Channel for incidents whose location matches no area rule (lib/area-channels.ts).
# Leave blank to skip unmatched incidents instead.
SLACK_DEFAULT_CHANNEL=#incidents

# Mapbox token for the static map attached to each incident (pk.… public token
# is fine — it ends up in the image URL). Blank = no map image.
MAPBOX_TOKEN=
# Same Mapbox public token, exposed to the browser so the board's incident modal
# can render a satellite view of the location. Blank = modal shows a map link
# instead of the satellite image. Safe to reuse the pk.… token above.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Anthropic key for friendly incident-type naming via Claude Haiku. Optional —
# without it, types are just title-cased. Only called on unknown short codes.
ANTHROPIC_API_KEY=

# ── Web push (PWA phone notifications) ───────────────────────────────────────
# Generate once:  npx web-push generate-vapid-keys --json
# Public key is shipped to the browser; private key stays on the feeder.
# Leave blank to disable phone push entirely (board still works).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact for the push service — a mailto: or https: URL.
VAPID_SUBJECT=mailto:you@example.com
